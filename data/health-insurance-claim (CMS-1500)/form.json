{
  "title": "Health Insurance Claim Form (CMS-1500)",
  "description": "Health Insurance Claim Form CMS-1500 (02/12), maintained by the National Uniform Claim Committee (NUCC). Field titles use the exact wording printed on the paper form to maximize vision-LLM extraction accuracy.",
  "logoPosition": "right",
  "showQuestionNumbers": "off",
  "showProgressBar": "top",
  "progressBarType": "pages",
  "showPreviewBeforeComplete": "showAllQuestions",
  "previewText": "Preview claim",
  "editText": "Edit claim",
  "completeText": "Submit claim",
  "pagePrevText": "Back",
  "pageNextText": "Next",
  "widthMode": "responsive",
  "questionTitleLocation": "top",
  "checkErrorsMode": "onValueChanged",
  "pages": [
    {
      "name": "carrier_section",
      "title": "CARRIER",
      "description": "The insurance company the claim is being mailed to.",
      "elements": [
        {
          "type": "text",
          "name": "carrier_name",
          "title": "Carrier Name",
          "isRequired": true
        },
        {
          "type": "text",
          "name": "carrier_address",
          "title": "Carrier Address"
        },
        {
          "type": "text",
          "name": "carrier_city_state_zip",
          "title": "Carrier City, State, ZIP",
          "placeholder": "CITY, ST 12345"
        }
      ]
    },
    {
      "name": "box1_insurance_type",
      "title": "1. Insurance Type and 1a. Insured's I.D. Number",
      "elements": [
        {
          "type": "radiogroup",
          "name": "insurance_type",
          "aiHint": "Box 1 has 7 small checkboxes in one horizontal row. The X mark sits at the LEFT edge of a column; the column's label and placeholder text are IMMEDIATELY TO THE RIGHT of the X. To identify the marked column: find the X, then read the text directly to its right (label above, placeholder in parens below). Columns left-to-right: 1=MEDICARE (Medicare#), 2=MEDICAID (Medicaid#), 3=TRICARE (ID#/DoD#), 4=CHAMPVA (Member ID#), 5=GROUP HEALTH PLAN (ID#), 6=FECA BLK LUNG (ID#), 7=OTHER (ID#). Examples: if the text right of the X starts with 'GROUP' or its placeholder is the FIRST '(ID#)' from the left, return 'group'. If the text right of the X is 'CHAMPVA' or '(Member ID#)', return 'champva'. ABSOLUTE RULE: NEVER return 'other' when uncertain — 'other' is only valid when the X is in the far-right checkbox, with 'OTHER' label literally to its right. If you see an X but cannot pinpoint the column, return the column whose text starts immediately to the right of the X, even if approximate.",
          "title": "1. MEDICARE / MEDICAID / TRICARE / CHAMPVA / GROUP HEALTH PLAN / FECA BLK LUNG / OTHER",
          "choices": [
            {
              "value": "medicare",
              "text": "Medicare"
            },
            {
              "value": "medicaid",
              "text": "Medicaid"
            },
            {
              "value": "tricare",
              "text": "TRICARE"
            },
            {
              "value": "champva",
              "text": "CHAMPVA"
            },
            {
              "value": "group",
              "text": "Group Health Plan"
            },
            {
              "value": "feca",
              "text": "FECA Black Lung"
            },
            {
              "value": "other",
              "text": "Other"
            }
          ],
          "colCount": 0,
          "isRequired": true
        },
        {
          "type": "text",
          "name": "insured_id",
          "aiHint": "Box 1a. Capture the entire alphanumeric ID exactly as printed, including letters, hyphens, and internal spaces (e.g., 'BSH 4827193 02'). Do not strip whitespace or punctuation.",
          "title": "1a. INSURED'S I.D. NUMBER",
          "isRequired": true,
          "description": "As it appears on the insurance card."
        }
      ]
    },
    {
      "name": "box2_patient",
      "title": "2, 3, 5. Patient Information",
      "elements": [
        {
          "type": "panel",
          "name": "box2_panel",
          "title": "2. PATIENT'S NAME (Last Name, First Name, Middle Initial)",
          "elements": [
            {
              "type": "text",
              "name": "patient_last_name",
              "title": "PATIENT'S NAME (Last Name)",
              "isRequired": true
            },
            {
              "type": "text",
              "name": "patient_first_name",
              "title": "PATIENT'S NAME (First Name)",
              "isRequired": true,
              "startWithNewLine": false
            },
            {
              "type": "text",
              "name": "patient_middle_init",
              "title": "PATIENT'S NAME (Middle Initial)",
              "maxLength": 1,
              "startWithNewLine": false
            }
          ]
        },
        {
          "type": "panel",
          "name": "box3_panel",
          "title": "3. PATIENT'S BIRTH DATE / SEX",
          "elements": [
            {
              "type": "text",
              "name": "patient_dob",
              "aiHint": "Box 3 left side. On the paper form, written as three small adjacent cells: MM | DD | YY (2-digit year). Convert to YYYY-MM-DD. For 2-digit birth-year disambiguation: 50-99 -> 19xx, 00-49 -> 20xx.",
              "title": "PATIENT'S BIRTH DATE",
              "inputType": "date",
              "isRequired": true
            },
            {
              "type": "radiogroup",
              "name": "patient_sex",
              "aiHint": "Box 3 right side (SEX). Two small checkboxes labeled M and F. The X sits immediately to the LEFT of the chosen letter. Return 'M' or 'F'.",
              "title": "SEX",
              "choices": [
                {
                  "value": "M",
                  "text": "Male"
                },
                {
                  "value": "F",
                  "text": "Female"
                }
              ],
              "colCount": 0,
              "isRequired": true,
              "startWithNewLine": false
            }
